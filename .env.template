# .env.template — Driver Guard Environment Variables
# ─────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.template .env
#
# .env is gitignored — never commit it.
# These values override config.yaml when set.

# ── Camera sources ────────────────────────────────────────
# Integer = OpenCV device index  |  String = RTSP/V4L2 URL
DG_DMS_CAMERA_SOURCE=0
DG_ROAD_CAMERA_SOURCE=1

# ── GPS serial port ───────────────────────────────────────
# Linux: /dev/ttyUSB0 or /dev/ttyAMA0
# Windows: COM3
DG_GPS_PORT=/dev/ttyUSB0

# ── GPIO buzzer (BCM pin number, blank = disabled) ────────
DG_BUZZER_GPIO_PIN=17

# ── Dashboard ─────────────────────────────────────────────
DG_DASHBOARD_HOST=0.0.0.0
DG_DASHBOARD_PORT=5000

# ── GPS simulation (true/false) ───────────────────────────
DG_GPS_SIMULATE=false

# ── Database path ─────────────────────────────────────────
DG_DB_PATH=data/logs/driver_guard_events.db

# ── Log level ─────────────────────────────────────────────
DG_LOG_LEVEL=INFO
